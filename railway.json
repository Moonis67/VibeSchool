{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install",
        "nixpacksPlan": {
            "providers": [
                "node"
            ]
        }
    },
    "deploy": {
        "startCommand": "node workers/document-worker.mjs",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}